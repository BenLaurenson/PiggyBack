# =============================================================================
# PiggyBack Environment Variables
# Copy this file to .env.local and fill in your values
# =============================================================================

# --- Required: Supabase ---
# Get these from your Supabase project dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Service role key — required for webhooks and cron jobs
# Get from Supabase dashboard > Settings > API > service_role (secret)
# WARNING: Never expose this in client-side code
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# --- Required: Encryption ---
# AES-256-GCM encryption key for storing Up Bank API tokens and AI API keys securely
# Must be exactly 64 hex characters (32 bytes). Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
UP_API_ENCRYPTION_KEY=your_64_hex_character_encryption_key

# --- Required for self-hosted / Recommended for all: App URL ---
# Your deployed URL — used for auth email redirects and Up Bank webhook registration
# On Vercel this falls back to VERCEL_URL automatically, but setting this explicitly is safer
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
#
# IMPORTANT: You must also configure these in your Supabase dashboard:
#   Authentication > URL Configuration:
#   - Site URL: https://your-app.vercel.app (or http://localhost:3005 for local dev)
#   - Redirect URLs (add both):
#     https://your-app.vercel.app/auth/callback
#     https://your-app.vercel.app/update-password
#
# NOTE: The dev server (npm run dev) runs on port 3005.
# Production builds (npm start / Docker) run on port 3000.

# --- Optional: Cron Jobs ---
# Secret token to authorize the daily notification cron job
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# CRON_SECRET=your_cron_secret

# --- Optional: Skip Landing Page ---
# Redirects authenticated users from / directly to /home
# Useful for personal deployments where you don't need the marketing page
# NEXT_PUBLIC_SKIP_LANDING=true

# --- Optional: AI Assistant ---
# No server-side API keys needed — users add their own in Settings > AI
# Supports: Google Gemini, OpenAI, Anthropic

# --- Price APIs ---
# Stock/ETF prices: Yahoo Finance (free, no key required)
# Crypto prices: CoinGecko (free, no key required)

# =============================================================================
# Hosted-platform variables (orchestrator-side only — leave blank for self-host)
# =============================================================================

# --- Stripe (test mode for staging, live for prod) ---
# STRIPE_SECRET_KEY="rk_test_..."           # restricted key, see /pricing
# STRIPE_PRICE_ID="price_..."               # price for the A$19/mo tier
# STRIPE_PRODUCT_ID="prod_..."              # product the price belongs to
# STRIPE_WEBHOOK_SECRET="whsec_..."         # from Stripe webhook endpoint config

# --- Vercel OAuth integration (for provisioning user Vercel projects) ---
# VERCEL_OAUTH_CLIENT_ID="oac_..."
# VERCEL_OAUTH_CLIENT_SECRET="..."
# VERCEL_API_TOKEN="vcp_..."                # personal token for ad-hoc API access
# NEXT_PUBLIC_VERCEL_INTEGRATION_SLUG="piggyback"

# --- Supabase OAuth app (for provisioning user Supabase projects) ---
# SUPABASE_OAUTH_CLIENT_ID="..."
# SUPABASE_OAUTH_CLIENT_SECRET="sba_..."
# NEXT_PUBLIC_SUPABASE_OAUTH_CLIENT_ID="..."   # public copy used to build authorize URLs
# SUPABASE_MANAGEMENT_TOKEN="sbp_..."          # personal token for ad-hoc Mgmt API

# --- Google OAuth (for sign-in to piggyback.finance hosted) ---
# GOOGLE_OAUTH_CLIENT_ID="...apps.googleusercontent.com"
# GOOGLE_OAUTH_CLIENT_SECRET="GOCSPX-..."

# --- Provisioner token vault (separate key from UP_API_ENCRYPTION_KEY) ---
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# PROVISIONER_ENCRYPTION_KEY="..."

# --- Hosted-platform feature flags + admin allow-list ---
# NEXT_PUBLIC_HOSTED_ENABLED="true"
# ADMIN_EMAILS="ben@example.com,partner@example.com"

# --- Environment indicator (renders a sticky banner on non-prod) ---
# NEXT_PUBLIC_ENVIRONMENT: "production" (or unset) | "staging" | "dev"
# Production deploys MUST leave this unset or set to "production".
# NEXT_PUBLIC_ENVIRONMENT="staging"

# --- Hosted-provisioner: which branch tenant Vercel projects track ---
# Production orchestrator: "main". Staging orchestrator: "dev".
# HOSTED_TRACK_BRANCH="main"
# HOSTED_REPO="BenLaurenson/PiggyBack"

# --- Up Bank Personal Access Token (smoke testing only — not committed) ---
# UP_BANK_PAT="up:yeah:..."

# --- Anthropic API key (Penny verification only — users provide their own) ---
# ANTHROPIC_API_KEY="sk-ant-..."
